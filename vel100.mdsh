# Create a new output device (change "128:0" to your correct MIDI output)
onew myout "128:0" ;

# Create a new input device (change "20:0" to your correct MIDI input)
inew myin "20:0" ;

# Create a filter to modify note-on velocity
fnew myfilter ;

# Set velocity of all note-on events to 100
fmap myfilter { note-on velocity set 100 } ;

# Apply the filter to incoming MIDI data
imap myin myfilter ;

# Send filtered MIDI data to output
omap myout myfilter ;
